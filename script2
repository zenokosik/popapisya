local serverSource = [==[
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local MessagingService = game:GetService("MessagingService")
local DataStoreService = game:GetService("DataStoreService")
local RunService = game:GetService("RunService")
local TeleportService = game:GetService("TeleportService")

local Shared = require(ReplicatedStorage:WaitForChild("AdminPanelShared"))

local ADMINS = Shared.ADMINS
local TOPIC = Shared.TOPIC

local tempBanStore = DataStoreService:GetDataStore("AdminTempBans_v3")
local permBanStore = DataStoreService:GetDataStore("AdminPermBans_v3")

local remotesFolder = ReplicatedStorage:FindFirstChild(Shared.REMOTES_FOLDER_NAME)
if not remotesFolder then
	remotesFolder = Instance.new("Folder")
	remotesFolder.Name = Shared.REMOTES_FOLDER_NAME
	remotesFolder.Parent = ReplicatedStorage
end

local function getOrCreate(className, name)
	local obj = remotesFolder:FindFirstChild(name)
	if not obj then
		obj = Instance.new(className)
		obj.Name = name
		obj.Parent = remotesFolder
	end
	return obj
end

local CheckAdminRF = getOrCreate("RemoteFunction", Shared.REMOTES.CheckAdmin)
local GetPlayersRF = getOrCreate("RemoteFunction", Shared.REMOTES.GetPlayersList)

local SetWalkSpeedRE = getOrCreate("RemoteEvent", Shared.REMOTES.SetWalkSpeed)
local SendGlobalMessageRE = getOrCreate("RemoteEvent", Shared.REMOTES.SendGlobalMessage)
local SendServerMessageRE = getOrCreate("RemoteEvent", Shared.REMOTES.SendServerMessage)
local FlyCommandRE = getOrCreate("RemoteEvent", Shared.REMOTES.FlyCommand)
local ShowGlobalMessageRE = getOrCreate("RemoteEvent", Shared.REMOTES.ShowGlobalMessage)
local PunishmentRE = getOrCreate("RemoteEvent", Shared.REMOTES.PunishmentAction)
local NotifyClientRE = getOrCreate("RemoteEvent", Shared.REMOTES.NotifyClient)
local TeleportRE = getOrCreate("RemoteEvent", Shared.REMOTES.TeleportAction)
local HealthRE = getOrCreate("RemoteEvent", Shared.REMOTES.HealthAction)
local MaskRE = getOrCreate("RemoteEvent", Shared.REMOTES.MaskAction)
local PrankRE = getOrCreate("RemoteEvent", Shared.REMOTES.PrankAction)
local ServerControlRE = getOrCreate("RemoteEvent", Shared.REMOTES.ServerControl)
local PunishmentTimerRE = getOrCreate("RemoteEvent", Shared.REMOTES.PunishmentTimer)

local mutedPlayers = {}
local mutedUntil = {}
local shieldedPlayers = {}
local invisiblePlayers = {}
local invisibleState = {}
local freezeTokens = {}
local muteTokens = {}
local serverLocked = false

local function debugLog(...)
	print("[AdminPanelServer]", ...)
end

local function isAdmin(player)
	return player and ADMINS[player.Name] == true
end

local function notify(player, title, text)
	if player then
		NotifyClientRE:FireClient(player, tostring(title), tostring(text))
	end
end

local function success(player, text)
	debugLog("SUCCESS", player and player.Name or "nil", text)
	notify(player, "Успешно", text)
end

local function fail(player, text)
	debugLog("ERROR", player and player.Name or "nil", text)
	notify(player, "Ошибка", text)
end

local function safeSet(store, key, value)
	local ok, err = pcall(function()
		store:SetAsync(key, value)
	end)
	if not ok then
		warn("DataStore SetAsync error:", err)
	end
	return ok
end

local function safeGet(store, key)
	local ok, result = pcall(function()
		return store:GetAsync(key)
	end)
	if not ok then
		warn("DataStore GetAsync error:", result)
		return nil
	end
	return result
end

local function safeRemove(store, key)
	local ok, err = pcall(function()
		store:RemoveAsync(key)
	end)
	if not ok then
		warn("DataStore RemoveAsync error:", err)
	end
	return ok
end

local function getPlayerByName(name)
	if typeof(name) ~= "string" or name == "" then
		return nil
	end

	for _, plr in ipairs(Players:GetPlayers()) do
		if plr.Name == name then
			return plr
		end
	end

	return nil
end

local function getUserIdFromName(name)
	local ok, result = pcall(function()
		return Players:GetUserIdFromNameAsync(name)
	end)

	if ok then
		return result
	end

	return nil
end

local function getHumanoid(player)
	if not player or not player.Character then
		return nil
	end
	return player.Character:FindFirstChildOfClass("Humanoid")
end

local function getRoot(player)
	if not player or not player.Character then
		return nil
	end
	return player.Character:FindFirstChild("HumanoidRootPart")
end

local function resolveTargetInfo(selectedName, typedName)
	local chosenName = nil

	if typeof(selectedName) == "string" and selectedName ~= "" then
		chosenName = selectedName
	elseif typeof(typedName) == "string" and typedName ~= "" then
		chosenName = typedName
	end

	if not chosenName then
		return nil, nil, nil
	end

	local onlinePlayer = getPlayerByName(chosenName)
	if onlinePlayer then
		return onlinePlayer, onlinePlayer.UserId, onlinePlayer.Name
	end

	local userId = getUserIdFromName(chosenName)
	if userId then
		return nil, userId, chosenName
	end

	return nil, nil, chosenName
end

local function applyShield(player)
	if not player or not player.Character then
		return
	end

	local humanoid = getHumanoid(player)
	if humanoid then
		humanoid.Health = humanoid.MaxHealth
	end

	local ff = player.Character:FindFirstChild("AdminShieldForceField")
	if not ff then
		ff = Instance.new("ForceField")
		ff.Name = "AdminShieldForceField"
		ff.Visible = false
		ff.Parent = player.Character
	end
end

local function removeShield(player)
	if not player or not player.Character then
		return
	end

	local ff = player.Character:FindFirstChild("AdminShieldForceField")
	if ff then
		ff:Destroy()
	end
end

local function setInvisible(player, enabled)
	if not player or not player.Character then
		return false
	end

	local char = player.Character
	local uid = player.UserId

	invisibleState[uid] = invisibleState[uid] or {}

	for _, obj in ipairs(char:GetDescendants()) do
		if obj:IsA("BasePart") then
			if enabled then
				if invisibleState[uid][obj] == nil then
					invisibleState[uid][obj] = {
						Transparency = obj.Transparency,
						CanCollide = obj.CanCollide
					}
				end
				obj.Transparency = 1
				obj.CanCollide = false
			else
				local saved = invisibleState[uid][obj]
				if saved then
					obj.Transparency = saved.Transparency
					obj.CanCollide = saved.CanCollide
				end
			end
		elseif obj:IsA("Decal") then
			if enabled then
				if invisibleState[uid][obj] == nil then
					invisibleState[uid][obj] = {
						Transparency = obj.Transparency
					}
				end
				obj.Transparency = 1
			else
				local saved = invisibleState[uid][obj]
				if saved then
					obj.Transparency = saved.Transparency
				end
			end
		end
	end

	if enabled then
		invisiblePlayers[uid] = true
	else
		invisiblePlayers[uid] = nil
		invisibleState[uid] = nil
	end

	return true
end

local function setFrozen(player, enabled)
	local root = getRoot(player)
	if not root then
		return false
	end

	root.Anchored = enabled
	return true
end

local function clearTimerForPlayer(player)
	if not player then
		return
	end
	PunishmentTimerRE:FireClient(player, "", 0)
end

local function stopMute(player, silent)
	if not player then
		return
	end

	local uid = player.UserId
	muteTokens[uid] = nil
	mutedPlayers[uid] = nil
	mutedUntil[uid] = nil
	clearTimerForPlayer(player)

	if not silent then
		notify(player, "Мут", "Мут снят")
	end
end

local function stopFreeze(player, silent)
	if not player then
		return
	end

	local uid = player.UserId
	freezeTokens[uid] = nil
	setFrozen(player, false)
	clearTimerForPlayer(player)

	if not silent then
		notify(player, "Заморозка", "Заморозка снята")
	end
end

local function startTimedMute(player, minutes)
	if not player then
		return false
	end

	minutes = tonumber(minutes) or 0
	if minutes <= 0 then
		return false
	end

	local seconds = math.max(1, math.floor(minutes * 60))
	local uid = player.UserId
	local token = tostring(os.clock()) .. "_mute_" .. tostring(uid)

	muteTokens[uid] = token
	mutedPlayers[uid] = true
	mutedUntil[uid] = os.time() + seconds

	task.spawn(function()
		for remaining = seconds, 1, -1 do
			if muteTokens[uid] ~= token then
				return
			end

			PunishmentTimerRE:FireClient(player, "Мут", remaining)
			task.wait(1)
		end

		if muteTokens[uid] == token then
			stopMute(player, true)
			notify(player, "Мут", "Мут закончился")
		end
	end)

	return true
end

local function startTimedFreeze(player, minutes)
	if not player then
		return false
	end

	minutes = tonumber(minutes) or 0
	if minutes <= 0 then
		return false
	end

	local seconds = math.max(1, math.floor(minutes * 60))
	local uid = player.UserId
	local token = tostring(os.clock()) .. "_freeze_" .. tostring(uid)

	if not setFrozen(player, true) then
		return false
	end

	freezeTokens[uid] = token

	task.spawn(function()
		for remaining = seconds, 1, -1 do
			if freezeTokens[uid] ~= token then
				return
			end

			PunishmentTimerRE:FireClient(player, "Заморозка", remaining)
			task.wait(1)
		end

		if freezeTokens[uid] == token then
			stopFreeze(player, true)
			notify(player, "Заморозка", "Заморозка закончилась")
		end
	end)

	return true
end

local function teleportPlayerToPlayer(playerA, playerB)
	if not playerA or not playerB then
		return false
	end

	local rootA = getRoot(playerA)
	local rootB = getRoot(playerB)
	if not rootA or not rootB then
		return false
	end

	rootA.CFrame = rootB.CFrame + Vector3.new(3, 0, 0)
	return true
end

local function setupPlayerState(player)
	player.CharacterAdded:Connect(function()
		task.defer(function()
			if shieldedPlayers[player.UserId] then
				applyShield(player)
			end

			if invisiblePlayers[player.UserId] then
				setInvisible(player, true)
			end

			if freezeTokens[player.UserId] then
				setFrozen(player, true)
			end
		end)
	end)
end

CheckAdminRF.OnServerInvoke = function(player)
	return isAdmin(player)
end

GetPlayersRF.OnServerInvoke = function(player)
	if not isAdmin(player) then
		return {}
	end

	local list = {}
	for _, plr in ipairs(Players:GetPlayers()) do
		table.insert(list, plr.Name)
	end

	table.sort(list)
	return list
end

Players.PlayerAdded:Connect(function(player)
	if serverLocked and not isAdmin(player) then
		player:Kick("Сервер закрыт администратором")
		return
	end

	local permBan = safeGet(permBanStore, tostring(player.UserId))
	if permBan == true then
		player:Kick("Вы забанены")
		return
	end

	local tempData = safeGet(tempBanStore, tostring(player.UserId))
	if tempData and tempData.untilTime then
		if os.time() < tempData.untilTime then
			local left = tempData.untilTime - os.time()
			player:Kick("Вы временно забанены. Осталось секунд: " .. tostring(left))
			return
		else
			safeRemove(tempBanStore, tostring(player.UserId))
		end
	end

	setupPlayerState(player)

	player.Chatted:Connect(function()
		if mutedPlayers[player.UserId] then
			notify(player, "Мут", "У вас мут")
		end
	end)
end)

for _, player in ipairs(Players:GetPlayers()) do
	setupPlayerState(player)
end

RunService.Heartbeat:Connect(function()
	for _, plr in ipairs(Players:GetPlayers()) do
		if shieldedPlayers[plr.UserId] then
			local humanoid = getHumanoid(plr)
			if humanoid and humanoid.Health < humanoid.MaxHealth then
				humanoid.Health = humanoid.MaxHealth
			end
		end
	end
end)

SetWalkSpeedRE.OnServerEvent:Connect(function(sender, targetName, speedValue)
	if not isAdmin(sender) then
		return
	end

	local target = getPlayerByName(targetName)
	local speed = tonumber(speedValue)

	if not target then
		fail(sender, "Игрок не найден для скорости")
		return
	end

	if not speed then
		fail(sender, "Введите число скорости")
		return
	end

	local humanoid = getHumanoid(target)
	if not humanoid then
		fail(sender, "У игрока нет Humanoid")
		return
	end

	humanoid.WalkSpeed = math.clamp(speed, 0, 500)
	success(sender, "Скорость " .. tostring(humanoid.WalkSpeed) .. " выдана игроку " .. target.Name)
end)

SendGlobalMessageRE.OnServerEvent:Connect(function(sender, text)
	if not isAdmin(sender) then
		return
	end

	if typeof(text) ~= "string" then
		fail(sender, "Некорректный текст сообщения")
		return
	end

	text = string.sub(text, 1, 200)
	if text == "" then
		fail(sender, "Введите текст сообщения")
		return
	end

	local ok, err = pcall(function()
		MessagingService:PublishAsync(TOPIC, {
			Author = sender.Name,
			Text = text
		})
	end)

	if not ok then
		warn("PublishAsync error:", err)
		ShowGlobalMessageRE:FireAllClients(sender.Name, text)
		success(sender, "Сообщение отправлено только на текущий сервер")
		return
	end

	success(sender, "Глобальное сообщение отправлено")
end)

SendServerMessageRE.OnServerEvent:Connect(function(sender, text)
	if not isAdmin(sender) then
		return
	end

	if typeof(text) ~= "string" then
		fail(sender, "Некорректный текст сообщения")
		return
	end

	text = string.sub(text, 1, 200)
	if text == "" then
		fail(sender, "Введите текст сообщения")
		return
	end

	ShowGlobalMessageRE:FireAllClients(sender.Name, text)
	success(sender, "Сообщение отправлено на этот сервер")
end)

FlyCommandRE.OnServerEvent:Connect(function(sender, targetName, enabled, speed)
	if not isAdmin(sender) then
		return
	end

	local target = getPlayerByName(targetName)
	if not target then
		fail(sender, "Игрок для флая не найден")
		return
	end

	FlyCommandRE:FireClient(target, enabled == true, tonumber(speed) or 50)
	success(sender, (enabled and "Флай включён для " or "Флай выключен для ") .. target.Name)
end)

PunishmentRE.OnServerEvent:Connect(function(sender, action, data)
	if not isAdmin(sender) then
		return
	end

	if typeof(data) ~= "table" then
		fail(sender, "Некорректные данные наказания")
		return
	end

	local selectedName = data.selectedTarget
	local typedName = data.typedName
	local minutes = tonumber(data.minutes) or 0

	local onlineTarget, userId, resolvedName = resolveTargetInfo(selectedName, typedName)

	if action == "Warn" then
		if not onlineTarget then
			fail(sender, "Варн можно выдать только игроку онлайн")
			return
		end

		notify(onlineTarget, "Варн", "Вам выдано предупреждение администратором")
		success(sender, "Варн выдан игроку " .. onlineTarget.Name)
		return
	end

	if action == "Mute" then
		if not onlineTarget then
			fail(sender, "Мут можно выдать только игроку онлайн")
			return
		end

		if minutes <= 0 then
			fail(sender, "Введите количество минут для мута")
			return
		end

		if startTimedMute(onlineTarget, minutes) then
			notify(onlineTarget, "Мут", "Вам выдан мут на " .. tostring(minutes) .. " мин.")
			success(sender, "Игроку " .. onlineTarget.Name .. " выдан мут на " .. tostring(minutes) .. " мин.")
		else
			fail(sender, "Не удалось выдать мут")
		end
		return
	end

	if action == "Unmute" then
		if not onlineTarget then
			fail(sender, "Размут можно сделать только игроку онлайн")
			return
		end

		stopMute(onlineTarget, true)
		notify(onlineTarget, "Мут", "Мут снят")
		success(sender, "Игроку " .. onlineTarget.Name .. " снят мут")
		return
	end

	if action == "Kick" then
		if not onlineTarget then
			fail(sender, "Кик можно сделать только игроку онлайн")
			return
		end

		success(sender, "Игрок " .. onlineTarget.Name .. " кикнут")
		onlineTarget:Kick("Кикнут администратором")
		return
	end

	if action == "TempBan" then
		if not userId or not resolvedName then
			fail(sender, "Игрок для временного бана не найден")
			return
		end

		if minutes <= 0 then
			fail(sender, "Введите количество минут")
			return
		end

		local untilTime = os.time() + math.floor(minutes * 60)
		safeSet(tempBanStore, tostring(userId), {
			untilTime = untilTime
		})

		if onlineTarget then
			onlineTarget:Kick("Вы временно забанены на " .. tostring(minutes) .. " минут")
		end

		success(sender, "Игрок " .. resolvedName .. " временно забанен на " .. tostring(minutes) .. " мин.")
		return
	end

	if action == "Ban" then
		if not userId or not resolvedName then
			fail(sender, "Игрок для перманентного бана не найден")
			return
		end

		safeSet(permBanStore, tostring(userId), true)

		if onlineTarget then
			onlineTarget:Kick("Вы забанены")
		end

		success(sender, "Игрок " .. resolvedName .. " перманентно забанен")
		return
	end

	if action == "Unban" then
		if not userId or not resolvedName then
			fail(sender, "Игрок для разбана не найден")
			return
		end

		safeRemove(permBanStore, tostring(userId))
		safeRemove(tempBanStore, tostring(userId))
		success(sender, "Игрок " .. resolvedName .. " разбанен")
		return
	end

	if action == "FreezeTimed" then
		if not onlineTarget then
			fail(sender, "Заморозить можно только игрока онлайн")
			return
		end

		if minutes <= 0 then
			fail(sender, "Введите количество минут для заморозки")
			return
		end

		if startTimedFreeze(onlineTarget, minutes) then
			notify(onlineTarget, "Заморозка", "Вы заморожены на " .. tostring(minutes) .. " мин.")
			success(sender, "Игрок " .. onlineTarget.Name .. " заморожен на " .. tostring(minutes) .. " мин.")
		else
			fail(sender, "Не удалось заморозить игрока")
		end
		return
	end

	if action == "Unfreeze" then
		if not onlineTarget then
			fail(sender, "Разморозить можно только игрока онлайн")
			return
		end

		stopFreeze(onlineTarget, true)
		notify(onlineTarget, "Заморозка", "Заморозка снята")
		success(sender, "Игрок " .. onlineTarget.Name .. " разморожен, таймер убран")
		return
	end

	fail(sender, "Неизвестное наказание")
end)

HealthRE.OnServerEvent:Connect(function(sender, action, data)
	if not isAdmin(sender) then
		return
	end

	if typeof(data) ~= "table" then
		fail(sender, "Некорректные данные здоровья")
		return
	end

	local target = getPlayerByName(data.target)
	if not target then
		fail(sender, "Игрок не найден")
		return
	end

	local humanoid = getHumanoid(target)
	if not humanoid then
		fail(sender, "У игрока нет Humanoid")
		return
	end

	if action == "Kill" then
		humanoid.Health = 0
		success(sender, "Игрок " .. target.Name .. " убит")
		return
	end

	if action == "Heal" then
		humanoid.Health = humanoid.MaxHealth
		success(sender, "Игрок " .. target.Name .. " вылечен")
		return
	end

	if action == "GiveShield" then
		shieldedPlayers[target.UserId] = true
		applyShield(target)
		success(sender, "Щит выдан игроку " .. target.Name)
		notify(target, "Щит", "Вам выдан щит")
		return
	end

	if action == "RemoveShield" then
		shieldedPlayers[target.UserId] = nil
		removeShield(target)
		success(sender, "Щит убран у " .. target.Name)
		notify(target, "Щит", "Щит убран")
		return
	end

	fail(sender, "Неизвестное действие здоровья")
end)

TeleportRE.OnServerEvent:Connect(function(sender, action, data)
	if not isAdmin(sender) then
		return
	end

	if typeof(data) ~= "table" then
		fail(sender, "Некорректные данные телепорта")
		return
	end

	if action ~= "PlayerToPlayer" then
		fail(sender, "Неизвестное действие телепорта")
		return
	end

	local player1 = getPlayerByName(data.player1)
	local player2 = getPlayerByName(data.player2)

	if not player1 or not player2 then
		fail(sender, "Выбери двух игроков")
		return
	end

	if teleportPlayerToPlayer(player1, player2) then
		success(sender, "Игрок " .. player1.Name .. " телепортирован к " .. player2.Name)
	else
		fail(sender, "Не удалось телепортировать игрока")
	end
end)

MaskRE.OnServerEvent:Connect(function(sender, action, data)
	if not isAdmin(sender) then
		return
	end

	if typeof(data) ~= "table" then
		fail(sender, "Некорректные данные маскировки")
		return
	end

	local target = getPlayerByName(data.target)
	if not target then
		fail(sender, "Игрок для маскировки не найден")
		return
	end

	if action == "Invisible" then
		if setInvisible(target, true) then
			success(sender, "Игрок " .. target.Name .. " стал невидимым")
