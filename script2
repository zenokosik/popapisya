PrankRE.OnServerEvent:Connect(function(sender, action, data)
	if not isAdmin(sender) then
		return
	end

	if typeof(data) ~= "table" then
		fail(sender, "Некорректные данные пранка")
		return
	end

	local target = getPlayerByName(data.target)
	if not target or not target.Character then
		fail(sender, "Игрок для пранка не найден")
		return
	end

	local character = target.Character
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	local root = character:FindFirstChild("HumanoidRootPart")

	if action == "Big" then
		if humanoid then
			local height = humanoid:FindFirstChild("BodyHeightScale")
			local width = humanoid:FindFirstChild("BodyWidthScale")
			local depth = humanoid:FindFirstChild("BodyDepthScale")
			local head = humanoid:FindFirstChild("HeadScale")

			if height then height.Value = 2 end
			if width then width.Value = 2 end
			if depth then depth.Value = 2 end
			if head then head.Value = 2 end

			success(sender, "Игрок " .. target.Name .. " увеличен")
		else
			fail(sender, "Не удалось увеличить игрока")
		end
		return
	end

	if action == "NormalSize" then
		if humanoid then
			local height = humanoid:FindFirstChild("BodyHeightScale")
			local width = humanoid:FindFirstChild("BodyWidthScale")
			local depth = humanoid:FindFirstChild("BodyDepthScale")
			local head = humanoid:FindFirstChild("HeadScale")

			if height then height.Value = 1 end
			if width then width.Value = 1 end
			if depth then depth.Value = 1 end
			if head then head.Value = 1 end

			success(sender, "Игрок " .. target.Name .. " возвращён к обычному размеру")
		else
			fail(sender, "Не удалось вернуть размер игрока")
		end
		return
	end

	if action == "Burn" then
		if root and not root:FindFirstChild("AdminFire") then
			local fire = Instance.new("Fire")
			fire.Name = "AdminFire"
			fire.Parent = root
		end
		success(sender, "Игрок " .. target.Name .. " подожжён")
		return
	end

	if action == "Unburn" then
		if root then
			local fire = root:FindFirstChild("AdminFire")
			if fire then
				fire:Destroy()
			end
		end
		success(sender, "Игрок " .. target.Name .. " потушен")
		return
	end

	if action == "Launch" then
		if root then
			root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
			root:ApplyImpulse(Vector3.new(0, root.AssemblyMass * 120, 0))
