		else
			fail(sender, "Не удалось подбросить игрока")
		end
		return
	end

	if action == "Seat" then
		if humanoid then
			humanoid.Sit = true
			success(sender, "Игрок " .. target.Name .. " посажен")
		else
			fail(sender, "Не удалось посадить игрока")
		end
		return
	end

	fail(sender, "Неизвестный пранк")
end)

ServerControlRE.OnServerEvent:Connect(function(sender, action)
	if not isAdmin(sender) then
		return
	end

	action = tostring(action or "")

	if action == "Lock" then
		serverLocked = true
		success(sender, "Сервер закрыт. Новые игроки не смогут зайти.")
		return
	end

	if action == "Unlock" then
		serverLocked = false
		success(sender, "Сервер открыт.")
		return
	end

	if action == "KickAll" then
		local kicked = 0
		for _, plr in ipairs(Players:GetPlayers()) do
			if plr ~= sender then
				kicked += 1
				plr:Kick("Все игроки были выгнаны администратором")
			end
		end
		success(sender, "Игроков выгнано: " .. tostring(kicked))
		return
	end

