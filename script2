		serverLocked = true
		success(sender, "Сервер закрывается.")
		for _, plr in ipairs(Players:GetPlayers()) do
			plr:Kick("Сервер закрыт администратором")
		end
		return
	end

	if action == "Restart" then
		serverLocked = true
		success(sender, "Перезапуск сервера запущен")

		local placeId = game.PlaceId
		for _, plr in ipairs(Players:GetPlayers()) do
